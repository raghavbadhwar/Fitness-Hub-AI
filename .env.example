# Clerk (required for non-Next.js apps in this workspace)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
# Optional hard gate for the admin portal. Prefer tenant mapping for multi-gym setups.
# Format: owner@example.com:gym-id,coowner@example.com:gym-id
DEFAULT_GYM_ID=gymos-main
ADMIN_GYM_OWNER_EMAILS=owner@example.com:gymos-main,coowner@example.com:gymos-main
# Legacy single-gym allowlist fallback. When unset, admin access falls back to Clerk owner metadata only.
ADMIN_ALLOWED_EMAILS=owner@example.com,coowner@example.com

# Admin web (Vite + @clerk/react)
VITE_CLERK_PUBLISHABLE_KEY=${CLERK_PUBLISHABLE_KEY}
VITE_CLERK_PROXY_URL=/api/__clerk

# Expo member app (@clerk/expo)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=${CLERK_PUBLISHABLE_KEY}
EXPO_PUBLIC_CLERK_PROXY_URL=/api/__clerk
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=

# API / shared runtime
PORT=4000
API_PORT=4000
API_BASE_URL=http://localhost:4000
BASE_PATH=/admin/
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3100
CLERK_PROXY_ENABLED=true
ADMIN_MEMBER_LIST_CACHE_TTL_MS=15000
# Use a dedicated runtime DB role in production. Quote the URLs because this file is sourced by the shell.
DATABASE_URL="postgresql://fitness_hub_app:change_me@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"
# Use the postgres admin connection only for schema changes and security hardening scripts.
DATABASE_ADMIN_URL="postgresql://postgres:change_me@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"
DATABASE_APP_ROLE=fitness_hub_app
DATABASE_APP_PASSWORD=change_me
AI_INTEGRATIONS_GEMINI_API_KEY=
# Required because the Gemini integration client fails fast without an explicit endpoint.
AI_INTEGRATIONS_GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.0-flash

# Expo / browser host helpers (optional for local multi-app dev)
# Always include protocol (http:// or https://) for EXPO_PUBLIC_API_BASE_URL and EXPO_PUBLIC_DOMAIN.
EXPO_PUBLIC_API_BASE_URL=${API_BASE_URL}
EXPO_PUBLIC_DOMAIN=
