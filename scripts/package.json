{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "beta-secrets-preflight": "tsx ./src/internal-beta-secret-preflight.ts",
    "beta-secrets-preflight:init": "tsx ./src/internal-beta-secret-preflight.ts --init",
    "beta-secrets-preflight:accept-risk": "tsx ./src/internal-beta-secret-preflight.ts --accept-risk",
    "node-version-preflight": "tsx ./src/node-version-preflight.ts",
    "production-env-preflight": "tsx ./src/production-env-preflight.ts",
    "test": "node --import tsx --test src/internal-beta-secret-preflight.test.ts src/node-version-preflight.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
