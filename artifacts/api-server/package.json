{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=${PORT:-4000} NODE_ENV=development pnpm run build && PORT=${PORT:-4000} NODE_ENV=development pnpm run start",
    "build": "node ./build.mjs",
    "start": "PORT=${PORT:-4000} node --enable-source-maps ./dist/index.mjs",
    "test": "node --experimental-test-module-mocks --experimental-transform-types --test --test-isolation=process",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@clerk/express": "^2.0.8",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-gemini-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0"
  }
}
